{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Start FastAPI",
      "type": "shell",
      "command": "cd ${workspaceFolder}/backend && source venv/bin/activate && PYTHONWARNINGS=ignore python -m uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend: Start Next.js",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start All Services",
      "dependsOn": [
        "Backend: Start FastAPI",
        "Frontend: Start Next.js"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
