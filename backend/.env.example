# ─── Neo4j (GraphRAG) ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ─── AWS Credentials ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-1

# ─── SageMaker Inference ──────────────────────────────────────────────────────
PROFUTURO_ENDPOINT=profuturo-auditor-tgi
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ─── SageMaker Training (lanzar_training_job.py) ──────────────────────────────
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/service-role/AmazonSageMaker-ExecutionRole
S3_TRAIN_URI=s3://your-bucket/profuturo/fine_tuning/data/train.jsonl
S3_OUTPUT_URI=s3://your-bucket/profuturo/fine_tuning/output
SAGEMAKER_BUCKET=your-s3-bucket
SAGEMAKER_JOB_NAME=profuturo-qwen25-7b-ft
SAGEMAKER_INSTANCE_TYPE=ml.g5.2xlarge

# ─── RPA — Email alerts ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASS=your_gmail_app_password

# ─── Embeddings (ingest_neo4j.py) ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# ─── Backend API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
